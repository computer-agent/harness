{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/index.tsx", "bin/mastersof-ai.js"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreBinaries": ["knip"]
    },
    "web": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["tailwindcss", "@tailwindcss/typography"],
      "ignoreBinaries": ["knip"]
    }
  }
}
